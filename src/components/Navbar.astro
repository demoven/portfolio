---
// src/components/Navbar.astro
const pathname = new URL(Astro.request.url).pathname;
---

<nav class="flex justify-between items-center p-6 bg-zinc-900 text-white shadow-lg">
  <div class="text-xl font-bold tracking-tight text-indigo-500">
    <a href="/">T.F. Portfolio</a>
  </div>

  <div class="flex items-center gap-6">
    <ul class="flex gap-8 list-none">
      <li>
        <a
          href="/cv"
          class={`hover:text-indigo-400 transition-colors ${pathname === '/cv' ? 'text-indigo-500 font-semibold' : ''}`}
          data-i18n="nav_about"
        >
          About Me
        </a>
      </li>
      <li>
        <a
          href="/projects"
          class={`hover:text-indigo-400 transition-colors ${pathname === '/projects' ? 'text-indigo-500 font-semibold' : ''}`}
          data-i18n="nav_projects"
        >
          Projects
        </a>
      </li>
    </ul>

    <!-- Language toggle button -->
    <button
      id="lang-toggle"
      data-current-lang="en"
      aria-label="Switch to French"
      class="lang-toggle-btn"
    >
      FR
    </button>
  </div>
</nav>

<style>
  .lang-toggle-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.5rem;
    background: transparent;
    border: 1.5px solid rgba(99, 102, 241, 0.4);
    color: #a5b4fc;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .lang-toggle-btn:hover {
    background: rgba(99, 102, 241, 0.15);
    border-color: #6366f1;
    color: #fff;
    transform: translateY(-1px);
  }

  .lang-toggle-btn:active {
    transform: scale(0.95);
  }
</style>